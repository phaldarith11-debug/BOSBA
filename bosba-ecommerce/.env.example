# ─────────────────────────────────────────────────────────────────────────────
# BOSBA eCommerce — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string
# Use the "Transaction" (pooled) URL for DATABASE_URL
# Use the "Session" (direct) URL for DIRECT_URL
PRISMA_CLIENT_ENGINE_TYPE="library"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL="https://luster-sprig-outlying.ngrok-free.dev"
NEXTAUTH_SECRET="your-random-32-char-secret-here"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client ID (Web application)
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Facebook OAuth ────────────────────────────────────────────────────────────
# https://developers.facebook.com → Create App → Add Facebook Login
# Valid OAuth Redirect URIs: http://localhost:3000/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ── Apple Sign In ─────────────────────────────────────────────────────────────
# Requires Apple Developer Program ($99/yr)
# https://developer.apple.com → Certificates, Identifiers & Profiles
# Service ID return URL: https://yourdomain.com/api/auth/callback/apple
APPLE_ID=""
APPLE_SECRET=""

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ── Cloudinary (image upload) ─────────────────────────────────────────────────
# https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com — free up to 3,000 emails/month
# Without this key, emails are printed to the dev console
RESEND_API_KEY=""
EMAIL_FROM="BOSBA <noreply@yourdomain.com>"

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather
# Used for order notification messages to admins
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_NAME=""

# ── ABA PayWay (payment) ──────────────────────────────────────────────────────
# Automatic PayWay is PAUSED. Manual ABA/KHQR (account details + screenshot proof)
# is used while ABA_PAYWAY_ENABLED=false. Configure the manual account details in
# the admin Settings page (account name/number/KHQR image), NOT here.
# Fill these and set ABA_PAYWAY_ENABLED=true once merchant creds + callback work.
ABA_MERCHANT_ID=
ABA_API_KEY=
ABA_PAYWAY_ENABLED=false
ABA_PAYWAY_URL=

# ── App Settings ──────────────────────────────────────────────────────────────
# Base URL used for absolute links (email, webhooks)
NEXT_PUBLIC_APP_URL="https://luster-sprig-outlying.ngrok-free.dev"
# Default USD/KHR exchange rate shown to users
NEXT_PUBLIC_DEFAULT_EXCHANGE_RATE="4100"
