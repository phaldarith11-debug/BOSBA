# ── API Base URL ─────────────────────────────────────────────────────────────
#
# Android EMULATOR (AVD):       http://10.0.2.2:3000
# Physical Android or iPhone:   http://YOUR_LAN_IP:3000
#   Find your LAN IP: run `ipconfig` on Windows (look for IPv4)
# Tunnel mode (no IP needed):   run `npm run tunnel`
# Production:                    https://your-bosba-domain.com
#
# IMPORTANT: Never use "localhost" on physical devices.
#
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# ── Public HTTPS URL (Google sign-in) ─────────────────────────────────────────
# Google sign-in uses a SERVER-SIDE OAuth flow (works in Expo Go). It needs the
# backend reachable over public HTTPS. Expose it with ngrok and put the URL here:
#   cd bosba-ecommerce && npx ngrok http 3000
# Register https://<ngrok>/api/mobile/auth/google/callback in Google Cloud Console
# (Web client → Authorized redirect URIs). Empty = falls back to EXPO_PUBLIC_API_URL.
EXPO_PUBLIC_PUBLIC_URL=

# ── Google OAuth (Mobile) ─────────────────────────────────────────────────────
# The server-side flow uses the backend's GOOGLE_CLIENT_ID/SECRET (bosba-ecommerce
# .env.local), so the values below are only needed if you later switch to the
# native @react-native-google-signin flow in a development build.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ── Facebook OAuth (Mobile) ───────────────────────────────────────────────────
# developers.facebook.com → Settings → Basic → App ID
EXPO_PUBLIC_FACEBOOK_APP_ID=

# ── Apple Sign In (iOS only) ──────────────────────────────────────────────────
# Handled natively. No env var needed. Requires Apple Developer Program ($99/yr).
